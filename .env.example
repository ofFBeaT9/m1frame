# Copy this file to .env and fill in your values
# The system reads these via os.environ — never hard-code keys in code.

# Anthropic Claude (required if backend=claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (required if backend=openai)
OPENAI_API_KEY=sk-...

# Local backends (Ollama / vLLM / LM Studio) need no key —
# just ensure the server is running on the configured port.
